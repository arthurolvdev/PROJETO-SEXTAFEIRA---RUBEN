<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= processo ? 'Editar' : 'Novo' %> Processo | Caio Ricson</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body class="admin-body">
  <aside class="admin-sidebar">
    <div class="sidebar-logo">
      <span class="logo-nome">Caio Ricson</span>
      <span class="logo-sub">Painel</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="sidebar-link">Dashboard</a>
      <a href="/" class="sidebar-link" target="_blank">Ver Site</a>
    </nav>
    <form action="/auth/logout" method="POST" class="sidebar-logout">
      <button type="submit" class="btn-logout">Sair</button>
    </form>
  </aside>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-titulo"><%= processo ? 'Editar Processo' : 'Novo Processo' %></h1>
      <a href="/admin" class="btn btn-secundario">← Voltar</a>
    </div>

    <% if (erro) { %>
      <div class="alerta alerta-erro"><%= erro %></div>
    <% } %>

    <div class="admin-form-card">
      <form action="/admin/processos/<%= processo ? 'editar/' + processo.id : 'novo' %>" method="POST" class="contato-form">
        <div class="campo">
          <label for="cliente_nome">Nome do cliente *</label>
          <input type="text" id="cliente_nome" name="cliente_nome" required placeholder="Nome completo" value="<%= processo ? processo.cliente_nome : '' %>">
        </div>
        <div class="campo">
          <label for="cliente_cpf">CPF do cliente *</label>
          <input type="text" id="cliente_cpf" name="cliente_cpf" required placeholder="000.000.000-00" value="<%= processo ? processo.cliente_cpf : '' %>">
        </div>
        <div class="campo">
          <label for="area">Área jurídica *</label>
          <select id="area" name="area" required>
            <option value="">Selecione...</option>
            <option value="Cível" <%= processo && processo.area === 'Cível' ? 'selected' : '' %>>Cível</option>
            <option value="Família" <%= processo && processo.area === 'Família' ? 'selected' : '' %>>Família</option>
            <option value="Criminal" <%= processo && processo.area === 'Criminal' ? 'selected' : '' %>>Criminal</option>
            <option value="Trabalhista" <%= processo && processo.area === 'Trabalhista' ? 'selected' : '' %>>Trabalhista</option>
          </select>
        </div>
        <div class="campo">
          <label for="status">Status *</label>
          <select id="status" name="status" required>
            <option value="Em andamento" <%= !processo || processo.status === 'Em andamento' ? 'selected' : '' %>>Em andamento</option>
            <option value="Aguardando audiência" <%= processo && processo.status === 'Aguardando audiência' ? 'selected' : '' %>>Aguardando audiência</option>
            <option value="Em recurso" <%= processo && processo.status === 'Em recurso' ? 'selected' : '' %>>Em recurso</option>
            <option value="Encerrado" <%= processo && processo.status === 'Encerrado' ? 'selected' : '' %>>Encerrado</option>
          </select>
        </div>
        <% if (processo) { %>
        <div class="campo">
          <label for="proxima_audiencia">Próxima audiência</label>
          <input type="date" id="proxima_audiencia" name="proxima_audiencia" value="<%= processo.proxima_audiencia || '' %>">
        </div>
        <% } %>
        <div class="campo">
          <label for="descricao">Descrição do caso *</label>
          <textarea id="descricao" name="descricao" rows="5" required placeholder="Descreva o caso do cliente..."><%= processo ? processo.descricao : '' %></textarea>
        </div>
        <div class="form-acoes">
          <button type="submit" class="btn btn-primario"><%= processo ? 'Salvar alterações' : 'Cadastrar processo' %></button>
          <a href="/admin" class="btn btn-secundario">Cancelar</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
